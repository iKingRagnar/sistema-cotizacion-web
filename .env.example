# ============================================================================
#  sistema-cotizacion-web — variables de entorno
#  Copia este archivo a .env (local) o configúralas en el panel de Render.
#  Solo el BLOQUE MÍNIMO es obligatorio; el resto es opcional.
#  No subas tu .env a git. Si una clave se filtró, revócala y genera otra.
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────
#  BLOQUE MÍNIMO (obligatorio en producción)
# ─────────────────────────────────────────────────────────────────────────
# Secreto para firmar los tokens de sesión. OBLIGATORIO en producción
# (el server aborta el arranque si falta). Usa una cadena larga y aleatoria:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=

# Contraseña inicial del usuario 'admin' que se crea en el primer arranque.
# OBLIGATORIA en producción (no se permite la clave por defecto). Cámbiala
# desde la app tras el primer login.
ADMIN_INITIAL_PASSWORD=

# Puerto. En Render/Docker lo define la plataforma; en local por defecto 3456.
# PORT=3456

# 'production' en el deploy; vacío o 'development' en local.
NODE_ENV=production

# ─────────────────────────────────────────────────────────────────────────
#  BASE DE DATOS (elige UNA opción; si ninguna se define → SQLite local)
# ─────────────────────────────────────────────────────────────────────────
# Opción A — Turso (libSQL):
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Opción B — Postgres / Supabase (cualquiera de las dos):
DATABASE_URL=
SUPABASE_POSTGRES_URL=
# Opción C — SQLite local: ruta del archivo (por defecto ~/.microsip-api/cotizacion.db)
# SQLITE_DB_PATH=

# ─────────────────────────────────────────────────────────────────────────
#  SEGURIDAD / AUTENTICACIÓN
# ─────────────────────────────────────────────────────────────────────────
# Orígenes permitidos para CORS (coma-separados). Por defecto el dominio de prod.
CORS_ORIGINS=https://sistema-cotizacion-web.onrender.com
# Días de validez del token de sesión (por defecto 7).
# AUTH_TOKEN_DAYS=7
# Poner 0 para DESACTIVAR la autenticación (solo desarrollo). Por defecto activa.
# AUTH_ENABLED=1
# Registrar mutaciones en audit_log (por defecto activado).
# AUDIT_ENABLED=1
# Token de un solo uso para el reset de emergencia del admin (déjalo vacío salvo que lo uses).
# ADMIN_RESET_TOKEN=
# Sembrar usuarios demo (usuario1/usuario2/operador/consulta) en el primer arranque.
# AUTH_SEED_DEMO_USERS=0
# Contraseñas iniciales de los usuarios demo (solo si AUTH_SEED_DEMO_USERS=1):
# USUARIO1_INITIAL_PASSWORD=
# USUARIO2_INITIAL_PASSWORD=
# OPERADOR_INITIAL_PASSWORD=
# CONSULTA_INITIAL_PASSWORD=
# SEED_USER_ZERG120_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────
#  CORREO (SMTP) — para reportes y notificaciones (opcional)
# ─────────────────────────────────────────────────────────────────────────
# Opción A — una sola URL:
# SMTP_URL=smtp://usuario:pass@host:587
# Opción B — campos separados:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_ADMIN_EMAIL=
# ADMIN_NOTIFY_EMAILS=
# ADMIN_DEFAULT_EMAILS=
# MONTHLY_ADMIN_EMAILS_ENABLED=0

# ─────────────────────────────────────────────────────────────────────────
#  IA (asistente / extracción de documentos) — opcional
# ─────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# AI_API_KEY=
# CURSOR_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
#  TIPO DE CAMBIO (USD/MXN) — opcional (hay fallbacks sin clave)
# ─────────────────────────────────────────────────────────────────────────
# BANXICO_TOKEN=
# BMX_TOKEN=
# BANXICO_SERIES=
# BANXICO_INTERVAL_HOURS=3
# FIXER_API_KEY=
# EXCHANGE_RATE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
#  RESPALDOS AUTOMÁTICOS — opcional
# ─────────────────────────────────────────────────────────────────────────
# BACKUP_AUTO_ENABLED=1
# BACKUP_AUTO_DIR=
# BACKUP_AUTO_INTERVAL_HOURS=24
# BACKUP_AUTO_MAX_FILES=14
# BACKUP_AUTO_MAX_AGE_DAYS=30

# ─────────────────────────────────────────────────────────────────────────
#  BRANDING (personalización de la app) — opcional
# ─────────────────────────────────────────────────────────────────────────
# APP_NAME=
# APP_SHORT_NAME=
# APP_TAGLINE=
# APP_LOGO_URL=
# APP_PRIMARY_HEX=
# APP_ACCENT_HEX=
# APP_SOUND_DEFAULT=

# ─────────────────────────────────────────────────────────────────────────
#  VARIOS — opcional
# ─────────────────────────────────────────────────────────────────────────
# Zona horaria del proceso (ej. America/Monterrey).
# TZ=America/Monterrey
# Al crear cotización, asegurar máquinas del cliente automáticamente.
# COTIZACION_AUTO_ENSURE_MAQUINAS=1
