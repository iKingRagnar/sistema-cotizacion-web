# Copia a .env y ajusta (no subas .env al repositorio)

PORT=3456

# SQLite local (persistente en disco). Déjalo vacío para usar ./data/cotizacion.db
# En nube, apunta esto a un disco persistente (ej. Render Disk).
# SQLITE_DB_PATH=./data/cotizacion.db

# Turso (opcional): si defines ambos, se usa Turso en lugar de SQLite local
# TURSO_DATABASE_URL=libsql://tu-db.turso.io
# TURSO_AUTH_TOKEN=tu-token-de-turso

# --- Autenticación (opcional; por defecto desactivada) ---
# AUTH_ENABLED=1
# Secreto largo y aleatorio para firmar tokens (obligatorio si AUTH_ENABLED=1)
# AUTH_SECRET=cambia-esto-por-una-cadena-larga-y-secreta-minimo-32-caracteres
# Días de validez del token (opcional)
# AUTH_TOKEN_DAYS=7

# Contraseñas iniciales solo si la tabla app_users está vacía (primera subida)
# ADMIN_INITIAL_PASSWORD=admin123
# OPERADOR_INITIAL_PASSWORD=operador123
# CONSULTA_INITIAL_PASSWORD=consulta123

# Desactivar escritura en audit_log (por defecto activa si hay usuario)
# AUDIT_ENABLED=0

# --- Marca / white-label (también puedes editar public/js/config.js) ---
# APP_NAME=Sistema de Cotización y Gestión
# APP_SHORT_NAME=Cotización Pro
# APP_TAGLINE=Cotizaciones, incidentes y bitácora en un solo lugar
# URL del logo en el header (opcional)
# APP_LOGO_URL=/mi-logo.png
# APP_PRIMARY_HEX=#1e3a5f
# APP_ACCENT_HEX=#0d9488

# Sonido de éxito activado por defecto en clientes nuevos (el usuario puede apagarlo en la UI)
# APP_SOUND_DEFAULT=0
