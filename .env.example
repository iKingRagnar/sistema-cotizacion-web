# Copiar a .env y completar. No subir .env a git.
# Si alguna clave API se filtró en chat o correo, revócala y genera otra.

# --- Vercel / producción (OBLIGATORIO en Vercel) ---
# Ejecuta: npm run vercel:env   → te sugiere AUTH_SECRET y recuerda Turso.
# Crea la base gratis: https://app.turso.tech → Create database → Connect (URL + token)
AUTH_SECRET=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local solo (no uses SQLite en Vercel; allí siempre Turso)
SQLITE_DB_PATH=

# Notificaciones por correo (aprobación cotización, garantías, futuros reportes mensuales)
# Usuario operativo que se recrea solo si no existe (misma BD nueva tras deploy). Recomendado definir en producción:
# SEED_USER_ZERG120_PASSWORD=tu_clave_segura
# (Si no defines la variable, el arranque usa un default de respaldo para Zerg120 / Alberto / rol usuario.)

# Admin principal (David): dcantu746@gmail.com — va por defecto en código si no defines nada.
# Lista fija personalizada (separada por comas; reemplaza los defaults):
# ADMIN_NOTIFY_EMAILS=dcantu746@gmail.com
# Correo adicional opcional (se suma a la lista por defecto si no está repetido):
# SMTP_ADMIN_EMAIL=

# Envío de correo (sin esto, aprobaciones/garantías no envían mail)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Correo mensual admin (comisiones + inventario refacciones): cron día 1, hora 6–10 en TZ.
# En Vercel no corre el scheduler; usar POST /api/admin/monthly-reports/run (admin) o Cron externo.
# TZ=America/Mexico_City
# MONTHLY_ADMIN_EMAILS_ENABLED=1

# Integraciones opcionales (solo variables; nunca pegar tokens en el código)
# Tipo de cambio: Banxico (SF43718) https://www.banxico.org.mx/SieAPIRest/service/v1/
BANXICO_TOKEN=
# Respaldo USD→MXN: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=
GITHUB_TOKEN=
NEWS_API_KEY=
ALPHA_VANTAGE_KEY=
HUGGINGFACE_TOKEN=
SERPER_API_KEY=
WEATHER_API_KEY=
DOCKER_PAT=
