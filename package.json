{
  "name": "sistema-cotizacion-web",
  "version": "1.0.0",
  "description": "Sistema de Cotización Universal — proyecto unificado (base funcional sistema-cotizacion-web backup + mejoras mapa tipo MapaSuminregio: clusters Leaflet)",
  "main": "v3/server.js",
  "scripts": {
    "build": "cd v3 && npm install --omit=dev",
    "start": "cd v3 && node server.js",
    "start:v1": "node server.js",
    "dev": "cd v3 && node --watch server.js",
    "seed": "cd v3 && node seed.js",
    "auth:reset-admin": "node scripts/reset-admin-password.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "jimp": "^1.6.1",
    "mammoth": "^1.8.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "exceljs": "^4.4.0"
  }
}
