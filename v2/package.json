{
  "name": "sistema-cotizacion-v2",
  "version": "2.0.0",
  "description": "Sistema de Cotización Web — Rebuild from zero. Stack: Vite + TS + Tailwind + Lit + Express + Drizzle + Turso.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n FE,BE -c blue,green \"npm run dev:fe\" \"npm run dev:be\"",
    "dev:fe": "vite",
    "dev:be": "tsx watch server/index.ts",
    "build": "npm run build:fe && npm run build:be",
    "build:fe": "tsc --noEmit && vite build",
    "build:be": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "lit": "^3.2.1",
    "express": "^4.21.1",
    "drizzle-orm": "^0.36.4",
    "@libsql/client": "^0.14.0",
    "zod": "^3.23.8",
    "jose": "^5.9.6",
    "bcryptjs": "^2.4.3",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.4.1",
    "cookie-parser": "^1.4.7"
  },
  "devDependencies": {
    "vite": "^5.4.11",
    "typescript": "^5.6.3",
    "tailwindcss": "^3.4.15",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "drizzle-kit": "^0.27.0",
    "tsx": "^4.19.2",
    "concurrently": "^9.1.0",
    "@types/node": "^22.9.0",
    "@types/express": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/cookie-parser": "^1.4.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
